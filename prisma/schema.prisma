generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["NAVTASK"]
}

model attachments {
  id            Int       @id @default(autoincrement())
  task_id       String    @db.Uuid
  file_name     String    @db.VarChar(255)
  original_name String    @db.VarChar(255)
  file_path     String
  mime_type     String?   @db.VarChar(100)
  file_size     BigInt?
  uploaded_at   DateTime? @default(now()) @db.Timestamp(6)
  task          task      @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task")

  @@schema("NAVTASK")
}

model subtask {
  id          Int             @id @default(autoincrement())
  task_id     String          @db.Uuid
  title       String          @db.VarChar(255)
  description String?
  status      subtask_status? @default(not_done)
  created_at  DateTime?       @default(now()) @db.Timestamp(6)
  task        task            @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task")

  @@schema("NAVTASK")
}

model task {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        Int
  title          String         @db.VarChar(255)
  description    String?
  due_date       DateTime?      @db.Date
  completed_date DateTime?      @db.Date
  priority       task_priority? @default(low)
  status         task_status?   @default(not_started)
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  attachments    attachments[]
  subtask        subtask[]
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user")

  @@schema("NAVTASK")
}

model users {
  id         Int            @id @default(autoincrement())
  username   String         @unique @db.VarChar(100)
  password   String         @db.VarChar(150)
  provider   provider_type? @default(local)
  created_at DateTime?      @default(now()) @db.Timestamp(6)
  task       task[]

  @@schema("NAVTASK")
}

enum provider_type {
  local
  facebook
  googlefb_and_google

  @@schema("NAVTASK")
}

enum subtask_status {
  done
  not_done @map("not-done")

  @@schema("NAVTASK")
}

enum task_priority {
  low
  high
  critical

  @@schema("NAVTASK")
}

enum task_status {
  not_started @map("not-started")
  in_progress @map("in-progress")
  completed
  cancelled

  @@schema("NAVTASK")
}
